{
  "title": "Docker Exporter",
  "uid": "docker-exporter",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "timezone": "browser",
  "templating": {
    "list": [
      {
        "name": "datasource",
        "type": "datasource",
        "pluginId": "prometheus",
        "query": "prometheus",
        "label": "Datasource",
        "hide": 0,
        "refresh": 1,
        "current": {}
      },
      {
        "name": "target",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "${datasource}" },
        "label": "Target",
        "hide": 0,
        "refresh": 2,
        "multi": true,
        "includeAll": true,
        "allValue": ".+",
        "query": {
          "query": "label_values(docker_mem_stat_bytes, instance)",
          "refId": "StandardVariableQuery"
        },
        "sort": 1
      },
      {
        "name": "container",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "${datasource}" },
        "label": "Container",
        "hide": 0,
        "refresh": 2,
        "multi": true,
        "includeAll": true,
        "allValue": ".+",
        "query": {
          "query": "label_values(docker_mem_stat_bytes{instance=~\"${target}\"}, containerName)",
          "refId": "StandardVariableQuery"
        },
        "sort": 1
      },
      {
        "name": "service",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "${datasource}" },
        "label": "Service",
        "hide": 0,
        "refresh": 2,
        "multi": true,
        "includeAll": true,
        "allValue": ".+",
        "query": {
          "query": "label_values(docker_mem_stat_bytes{instance=~\"${target}\"}, serviceName)",
          "refId": "StandardVariableQuery"
        },
        "sort": 1
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "row",
      "title": "Overview",
      "gridPos": { "x": 0, "y": 0, "w": 24, "h": 1 },
      "collapsed": false
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Running Containers",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "x": 0, "y": 1, "w": 6, "h": 4 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "auto",
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "blue" },
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "blue", "value": null }]
          }
        }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "count(count by (containerName) (docker_mem_stat_bytes{instance=~\"${target}\", containerName=~\"${container}\", serviceName=~\"${service}\"}))",
          "legendFormat": "Containers"
        }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "OOM Events (last hour)",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "x": 6, "y": 1, "w": 6, "h": 4 },
      "options": {
        "reduceOptions": { "calcs": ["sum"] },
        "orientation": "auto",
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          }
        }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "increase(docker_event{instance=~\"${target}\", eventType=\"oom\", containerName=~\"${container}\", serviceName=~\"${service}\"}[$__range])",
          "legendFormat": "OOM Events"
        }
      ]
    },
    {
      "id": 4,
      "type": "row",
      "title": "CPU",
      "gridPos": { "x": 0, "y": 5, "w": 24, "h": 1 },
      "collapsed": false
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "CPU Usage (usermode + kernelmode)",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "x": 0, "y": 6, "w": 12, "h": 8 },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["lastNotNull", "max"] }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ns",
          "custom": { "lineWidth": 1, "fillOpacity": 5 }
        }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "docker_cpu_stat_ns{type=\"usermode\", instance=~\"${target}\", containerName=~\"${container}\", serviceName=~\"${service}\"} + ignoring(type) docker_cpu_stat_ns{type=\"kernelmode\", instance=~\"${target}\", containerName=~\"${container}\", serviceName=~\"${service}\"}",
          "legendFormat": "{{containerName}} ({{instance}})"
        }
      ]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "CPU Throttled Time",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "x": 12, "y": 6, "w": 12, "h": 8 },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["lastNotNull", "max"] }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ns",
          "custom": { "lineWidth": 1, "fillOpacity": 5 },
          "color": { "mode": "palette-classic" }
        }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "docker_cpu_stat_ns{type=\"throttled\", instance=~\"${target}\", containerName=~\"${container}\", serviceName=~\"${service}\"}",
          "legendFormat": "{{containerName}} ({{instance}})"
        }
      ]
    },
    {
      "id": 7,
      "type": "row",
      "title": "Memory",
      "gridPos": { "x": 0, "y": 14, "w": 24, "h": 1 },
      "collapsed": false
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "Memory Usage",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "x": 0, "y": 15, "w": 24, "h": 8 },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["lastNotNull", "max"] }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "custom": { "lineWidth": 1, "fillOpacity": 10 }
        }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "docker_mem_stat_bytes{type=\"used\", instance=~\"${target}\", containerName=~\"${container}\", serviceName=~\"${service}\"}",
          "legendFormat": "{{containerName}} ({{instance}})"
        }
      ]
    },
    {
      "id": 9,
      "type": "row",
      "title": "Network",
      "gridPos": { "x": 0, "y": 23, "w": 24, "h": 1 },
      "collapsed": false
    },
    {
      "id": 10,
      "type": "timeseries",
      "title": "Network Received (RX)",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "x": 0, "y": 24, "w": 12, "h": 8 },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["lastNotNull", "max"] }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "custom": { "lineWidth": 1, "fillOpacity": 5 }
        }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "docker_net_stat_bytes{type=\"rx\", instance=~\"${target}\", containerName=~\"${container}\", serviceName=~\"${service}\"}",
          "legendFormat": "{{containerName}} ({{instance}})"
        }
      ]
    },
    {
      "id": 11,
      "type": "timeseries",
      "title": "Network Transmitted (TX)",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "x": 12, "y": 24, "w": 12, "h": 8 },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["lastNotNull", "max"] }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "custom": { "lineWidth": 1, "fillOpacity": 5 }
        }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "docker_net_stat_bytes{type=\"tx\", instance=~\"${target}\", containerName=~\"${container}\", serviceName=~\"${service}\"}",
          "legendFormat": "{{containerName}} ({{instance}})"
        }
      ]
    },
    {
      "id": 12,
      "type": "timeseries",
      "title": "Network Drops",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "x": 0, "y": 32, "w": 12, "h": 8 },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["lastNotNull", "max"] }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "custom": { "lineWidth": 1, "fillOpacity": 5 },
          "color": { "mode": "fixed", "fixedColor": "orange" }
        }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "docker_net_stat_bytes{type=\"drop\", instance=~\"${target}\", containerName=~\"${container}\", serviceName=~\"${service}\"}",
          "legendFormat": "{{containerName}} ({{instance}})"
        }
      ]
    },
    {
      "id": 13,
      "type": "timeseries",
      "title": "Network Errors",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "x": 12, "y": 32, "w": 12, "h": 8 },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["lastNotNull", "max"] }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "custom": { "lineWidth": 1, "fillOpacity": 5 },
          "color": { "mode": "fixed", "fixedColor": "red" }
        }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "docker_net_stat_bytes{type=\"error\", instance=~\"${target}\", containerName=~\"${container}\", serviceName=~\"${service}\"}",
          "legendFormat": "{{containerName}} ({{instance}})"
        }
      ]
    },
    {
      "id": 14,
      "type": "row",
      "title": "Events",
      "gridPos": { "x": 0, "y": 40, "w": 24, "h": 1 },
      "collapsed": false
    },
    {
      "id": 15,
      "type": "timeseries",
      "title": "OOM Events",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "x": 0, "y": 41, "w": 24, "h": 8 },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["sum"] }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 20,
            "drawStyle": "bars"
          },
          "color": { "mode": "fixed", "fixedColor": "red" }
        }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "increase(docker_event{eventType=\"oom\", instance=~\"${target}\", containerName=~\"${container}\", serviceName=~\"${service}\"}[$__rate_interval])",
          "legendFormat": "{{containerName}} ({{instance}})"
        }
      ]
    }
  ]
}
